# 应用配置
APP_NAME=CloudDisk
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库配置
DATABASE_URL=sqlite:///./data/database.db

# 上传配置
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=500
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp,webp,pdf,doc,docx,xls,xlsx,ppt,pptx,txt,zip,rar,7z,tar.gz,mp4,avi,mkv,mp3,wav,flac,bin

# 管理员默认账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@cloud-disk.local

# 注册开关
ALLOW_REGISTRATION=true
